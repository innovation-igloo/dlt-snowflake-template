# secrets.toml.example — copy to secrets.toml and fill in real values.
# secrets.toml is git-ignored; this example file is safe to commit.
#
# HOW SECRET REFS WORK
# In registry.yml, any credential value prefixed with "secret:" is treated as
# a dlt.secrets path (e.g. "secret:sources.pg_public.credentials.password").
# Literal values (no prefix) are used as-is.

# ---------------------------------------------------------------------------
# DESTINATION: Snowflake
# ---------------------------------------------------------------------------
# External runs (local dev, CI) — key-pair auth:
[destination.snowflake.credentials]
host              = "YOUR_ACCOUNT_IDENTIFIER"   # dlt's "host" = Snowflake account identifier, e.g. xy12345.us-east-1
username          = "DLT_LOADER"
role              = "DLT_LOADER_ROLE"
warehouse         = "DLT_WH"
database          = "DLT_DB"
# Provide EITHER private_key (inline PEM, newlines as \n) OR private_key_path:
private_key       = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# private_key_path = "/path/to/rsa_key.p8"
# private_key_passphrase = ""   # set if the key is encrypted

# In-SPCS runs use OAuth instead of key-pair.
# The runner sets DESTINATION__SNOWFLAKE__CREDENTIALS__AUTHENTICATOR=oauth
# automatically; no changes to this file are needed for that mode.

# ---------------------------------------------------------------------------
# SOURCE: pg_public  (sql_database pipeline)
# ---------------------------------------------------------------------------
[sources.pg_public.credentials]
drivername = "postgresql+psycopg2"
host       = "your-postgres-host"
port       = 5432
database   = "your_database"
username   = "your_user"
password   = "your_password"

# ---------------------------------------------------------------------------
# SOURCE: github_issues  (rest_api pipeline)
# ---------------------------------------------------------------------------
[sources.github_issues]
token = "ghp_your_github_personal_access_token"
